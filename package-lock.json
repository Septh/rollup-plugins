    "plugins/package-type": {
      "name": "rollup-plugin-package-type",
      "version": "0.0.1",
      "license": "MIT",
      "devDependencies": {
        "rollup": "^3.13.0"
      },
      "engines": {
        "node": ">=16.0.0"
      },
      "peerDependencies": {
        "rollup": "^2.60.0 || ^3.0.0"
      }
    }
