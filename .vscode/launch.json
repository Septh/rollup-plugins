{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "changelog",
            "presentation": {
                "hidden": false,
                "group": "scripts",
                "order": 1
            },
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/plugins/fast-typescript",
            "program": "${workspaceFolder}/scripts/changelog/cli.js",
            "args": [
                "--debug", "--dry-run"
            ],
            "console": "integratedTerminal",
            "outputCapture": "std",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        }
    ]
}
